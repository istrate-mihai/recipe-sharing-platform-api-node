# .env — copy to Railway as environment variables

NODE_ENV=production
PORT=3000

# Railway PostgreSQL — get from Railway dashboard after adding PostgreSQL service
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_byte_random_secret_here
JWT_EXPIRES_IN=30d

# Cloudflare R2 — same values as Laravel .env
R2_ACCESS_KEY_ID=2703452ae23d0bb74f8b2b783d550dba
